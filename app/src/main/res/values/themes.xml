<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.PESUflow" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/pure_white</item>
        <item name="colorOnPrimary">@color/midnight_black</item>
        <item name="colorPrimaryContainer">@color/chip_surface</item>
        <item name="colorOnPrimaryContainer">@color/pure_white</item>
        <item name="colorSecondary">@color/steel_grey</item>
        <item name="colorOnSecondary">@color/midnight_black</item>
        <item name="colorSurface">@color/midnight_black</item>
        <item name="colorSurfaceVariant">@color/midnight_black_soft</item>
        <item name="colorOnSurface">@color/pure_white</item>
        <item name="colorOnSurfaceVariant">@color/steel_grey</item>
        <item name="android:colorBackground">@color/midnight_black</item>
        <item name="android:textColorPrimary">@color/pure_white</item>
        <item name="android:textColorSecondary">@color/steel_grey</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/midnight_black</item>
        <item name="android:navigationBarColor">@color/midnight_black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="materialButtonStyle">@style/Widget.PESUflow.Button</item>
        <item name="materialSwitchStyle">@style/Widget.PESUflow.Switch</item>
    </style>

    <style name="Widget.PESUflow.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">18dp</item>
    </style>

    <style name="Widget.PESUflow.Switch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="thumbTint">@color/pure_white</item>
        <item name="trackTint">@color/graphite</item>
    </style>
</resources>
