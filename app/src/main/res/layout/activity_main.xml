<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/midnight_black"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
        android:textColor="@color/pure_white"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textProfileSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/profile_summary_placeholder"
        android:textColor="@color/steel_grey" />

    <TextView
        android:id="@+id/textSyncStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/no_sync_yet"
        android:textColor="@color/steel_grey" />

    <Button
        android:id="@+id/buttonRefreshNow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/refresh_now" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchTestMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/test_mode_label"
        android:textColor="@color/pure_white"
        app:trackTint="@color/graphite" />

    <Button
        android:id="@+id/buttonEditProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/edit_profile" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/filter_categories"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
        android:textColor="@color/pure_white"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/preferences_hint"
        android:textColor="@color/steel_grey" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchExams"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:checked="true"
        android:text="@string/exams_label"
        android:textColor="@color/pure_white"
        app:trackTint="@color/graphite" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchAssignments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:checked="true"
        android:text="@string/assignments_label"
        android:textColor="@color/pure_white"
        app:trackTint="@color/graphite" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchInternships"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:checked="true"
        android:text="@string/internships_label"
        android:textColor="@color/pure_white"
        app:trackTint="@color/graphite" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switchGeneral"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:checked="true"
        android:text="@string/general_label"
        android:textColor="@color/pure_white"
        app:trackTint="@color/graphite" />

    <TextView
        android:id="@+id/textEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/no_announcements_found"
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
        android:textColor="@color/pure_white"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAnnouncements"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <Button
        android:id="@+id/buttonOpenLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/open_history" />

</LinearLayout>
